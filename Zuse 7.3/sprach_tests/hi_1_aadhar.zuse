# hi_1_aadhar.zuse - Hindi Program 1: Aadhar (Basics)
दिखाओ "=== हिंदी आधार ==="

# चर
नाम = "Zuse"
संख्या = 42
दशमलव = 3.14
सत्यता = सत्य
कुछनहीं_चर = कुछनहीं

दिखाओ "नाम: " + नाम
दिखाओ "संख्या: " + पाठ_में(संख्या)
दिखाओ "दशमलव: " + पाठ_में(दशमलव)
दिखाओ "सत्यता: " + पाठ_में(सत्यता)
दिखाओ "कुछनहीं: " + पाठ_में(कुछनहीं_चर)

# शर्तें अगर / वरना अगर / वरना
उम्र = 20
अगर उम्र < 18 तो
    दिखाओ "नाबालिग"
वरना अगर उम्र < 65 तो
    दिखाओ "वयस्क"
वरना
    दिखाओ "बुजुर्ग"
अंत अगर

# चुनो/स्थिति
दिन = 3
चुनो दिन
    स्थिति 1 तो
        दिखाओ "सोमवार"
    स्थिति 2 तो
        दिखाओ "मंगलवार"
    स्थिति 3 तो
        दिखाओ "बुधवार"
    स्थिति 4 तो
        दिखाओ "गुरुवार"
    वरना
        दिखाओ "अन्य दिन"
अंत चुनो

# हर चक्र
दिखाओ "--- हर चक्र ---"
चक्र हर i में श्रेणी(1, 6) करो
    दिखाओ "i = " + पाठ_में(i)
अंत चक्र

# जबतक चक्र रुको और जारी के साथ
दिखाओ "--- जबतक चक्र ---"
n = 0
चक्र जबतक n < 10 करो
    n = n + 1
    अगर n == 3 तो
        जारी
    अंत अगर
    अगर n == 7 तो
        रुको
    अंत अगर
    दिखाओ "n = " + पाठ_में(n)
अंत चक्र

# डिफ़ॉल्ट पैरामीटर के साथ फ़ंक्शन
परिभाषा अभिवादन(व्यक्ति, नमस्कार="नमस्ते"):
    परिणाम है नमस्कार + ", " + व्यक्ति + "!"
अंत फलन

दिखाओ अभिवादन("दुनिया")
दिखाओ अभिवादन("राम", "सुप्रभात")

# लैम्बडा
दोगुना = क्रिया(x): x * 2
दिखाओ "Lambda: " + पाठ_में(दोगुना(5))

# विरासत के साथ कक्षाएं
वर्ग जानवर:
    परिभाषा बनाओ(नाम, प्रजाति):
        मेरा.नाम = नाम
        मेरा.प्रजाति = प्रजाति
    अंत फलन
    परिभाषा परिचय():
        परिणाम है मेरा.नाम + " एक " + मेरा.प्रजाति + " है"
    अंत फलन
अंत वर्ग

वर्ग कुत्ता(जानवर):
    परिभाषा बनाओ(नाम):
        पूर्वज.बनाओ(नाम, "कुत्ता")
        मेरा.तरकीबें = []
    अंत फलन
    परिभाषा तरकीब_सीखो(तरकीब):
        मेरा.तरकीबें = जोड़ो_अंत(मेरा.तरकीबें, तरकीब)
    अंत फलन
    परिभाषा जानकारी():
        परिणाम है मेरा.परिचय() + " | तरकीबें: " + पाठ_में(लंबाई(मेरा.तरकीबें))
    अंत फलन
अंत वर्ग

rex = कुत्ता("Rex")
rex.तरकीब_सीखो("बैठो")
rex.तरकीब_सीखो("रुको")
दिखाओ rex.जानकारी()

# त्रुटि प्रबंधन
प्रयास
    x = 1 / 0
पकड़ो त्रुटि
    दिखाओ "त्रुटि पकड़ी: " + पाठ_में(त्रुटि)
अंत प्रयास

# सूचियाँ
संख्याएं = [5, 3, 1, 4, 2]
संख्याएं = जोड़ो_अंत(संख्याएं, 6)
क्रमित = क्रमबद्ध(संख्याएं)
उलटा = उलटाओ(क्रमित)
दिखाओ "सूची: " + पाठ_में(संख्याएं)
दिखाओ "क्रमित: " + पाठ_में(क्रमित)
दिखाओ "उलटा: " + पाठ_में(उलटा)

# शब्दकोश
व्यक्ति = {"नाम": "अनु", "उम्र": 30, "शहर": "दिल्ली"}
दिखाओ "व्यक्ति: " + पाठ_में(व्यक्ति)
दिखाओ "नाम: " + व्यक्ति["नाम"]

# Slicing
पाठ_सूची = ["a", "b", "c", "d", "e"]
दिखाओ "Slice [1:3]: " + पाठ_में(पाठ_सूची[1:3])

# वैश्विक
गिनती = 0
परिभाषा बढ़ाओ():
    वैश्विक गिनती
    गिनती = गिनती + 1
अंत फलन
बढ़ाओ()
बढ़ाओ()
दिखाओ "वैश्विक गिनती: " + पाठ_में(गिनती)

# PASS
परिभाषा खाली_फ़ंक्शन():
    PASS
अंत फलन
खाली_फ़ंक्शन()
दिखाओ "PASS काम करता है"

# स्ट्रिंग विधियाँ
s = "  नमस्ते दुनिया  "
दिखाओ "ट्रिम: '" + छाँटो(s) + "'"
दिखाओ "बड़े: " + बड़े_अक्षर(छाँटो(s))
दिखाओ "छोटे: " + छोटे_अक्षर(छाँटो(s))
दिखाओ "बदलें: " + बदलो(छाँटो(s), "दुनिया", "Zuse")
भाग = विभाजित("a,b,c,d", ",")
दिखाओ "विभाजित: " + पाठ_में(भाग)
दिखाओ "शामिल 'नमस्ते': " + पाठ_में(शामिल_है(s, "नमस्ते"))
दिखाओ "खोजें 'दुनिया': " + पाठ_में(खोजो(छाँटो(s), "दुनिया"))
दिखाओ "से शुरू 'नमस्ते': " + पाठ_में(शुरू_होता(छाँटो(s), "नमस्ते"))
दिखाओ "पर समाप्त 'दुनिया': " + पाठ_में(अंत_होता(छाँटो(s), "दुनिया"))

# बुनियादी Builtins
संख्याएं2 = [3, 1, 4, 1, 5, 9, 2, 6]
दिखाओ "लंबाई: " + पाठ_में(लंबाई(संख्याएं2))
दिखाओ "अधिकतम: " + पाठ_में(अधिकतम(संख्याएं2))
दिखाओ "न्यूनतम: " + पाठ_में(न्यूनतम(संख्याएं2))
दिखाओ "निरपेक्ष(-5): " + पाठ_में(निरपेक्ष(-5))
दिखाओ "गोल(3.7): " + पाठ_में(गोल(3.7))
दिखाओ "वर्गमूल(16): " + पाठ_में(वर्गमूल(16))
दिखाओ "संख्या_में('42'): " + पाठ_में(संख्या_में("42"))
दिखाओ "है_संख्या(42): " + पाठ_में(है_संख्या(42))
दिखाओ "है_पाठ('hi'): " + पाठ_में(है_पाठ("hi"))
दिखाओ "है_सूची([]): " + पाठ_में(है_सूची([]))
दिखाओ "है_शब्दकोश({}): " + पाठ_में(है_शब्दकोश({}))
दिखाओ "है_बूल(सत्य): " + पाठ_में(है_बूल(सत्य))
दिखाओ "है_कुछनहीं(कुछनहीं): " + पाठ_में(है_कुछनहीं(कुछनहीं))

दिखाओ "=== हिंदी आधार समाप्त ==="
