# zh_1_jichu.zuse - Chinese Program 1: Basics (基础)
输出 "=== 中文基础 ==="

# 变量
名字 = "Zuse"
数字 = 42
小数 = 3.14
真值 = 真
空值 = 空

输出 "名字: " + 名字
输出 "数字: " + 转为_文字(数字)
输出 "小数: " + 转为_文字(小数)
输出 "真值: " + 转为_文字(真值)
输出 "空: " + 转为_文字(空值)

# 条件 如果 / 否则 如果 / 否则
年龄 = 20
如果 年龄 < 18 则
    输出 "未成年"
否则 如果 年龄 < 65 则
    输出 "成年人"
否则
    输出 "老年人"
结束 如果

# 选择/情况
日 = 3
选择 日
    情况 1 则
        输出 "星期一"
    情况 2 则
        输出 "星期二"
    情况 3 则
        输出 "星期三"
    情况 4 则
        输出 "星期四"
    否则
        输出 "其他天"
结束 选择

# 每个循环
输出 "--- 每个循环 ---"
循环 每个 i 在 范围(1, 6) 执行
    输出 "i = " + 转为_文字(i)
结束 循环

# 当循环 带中断和继续
输出 "--- 当循环 ---"
n = 0
循环 当 n < 10 执行
    n = n + 1
    如果 n == 3 则
        继续
    结束 如果
    如果 n == 7 则
        中断
    结束 如果
    输出 "n = " + 转为_文字(n)
结束 循环

# 带默认参数的函数
定义 问候(人, 打招呼="你好"):
    返回 打招呼 + ", " + 人 + "!"
结束 函数

输出 问候("世界")
输出 问候("小明", "早上好")

# 匿名函数
加倍 = 匿名(x): x * 2
输出 "Lambda: " + 转为_文字(加倍(5))

# 带继承的类
类 动物:
    定义 创建(名字, 种类):
        自己.名字 = 名字
        自己.种类 = 种类
    结束 函数
    定义 介绍():
        返回 自己.名字 + " 是一只 " + 自己.种类
    结束 函数
结束 类

类 狗(动物):
    定义 创建(名字):
        父类.创建(名字, "狗")
        自己.技巧 = []
    结束 函数
    定义 学技巧(技巧):
        自己.技巧 = 追加(自己.技巧, 技巧)
    结束 函数
    定义 信息():
        返回 自己.介绍() + " | 技巧数: " + 转为_文字(长度(自己.技巧))
    结束 函数
结束 类

rex = 狗("Rex")
rex.学技巧("坐下")
rex.学技巧("握手")
输出 rex.信息()

# 错误处理
尝试
    x = 1 / 0
捕获 错误
    输出 "捕获到错误: " + 转为_文字(错误)
结束 尝试

# 列表
数字列 = [5, 3, 1, 4, 2]
数字列 = 追加(数字列, 6)
排序的 = 排序(数字列)
颠倒的 = 反转(排序的)
输出 "列表: " + 转为_文字(数字列)
输出 "排序: " + 转为_文字(排序的)
输出 "颠倒: " + 转为_文字(颠倒的)

# 字典
人员 = {"名字": "小红", "年龄": 30, "城市": "北京"}
输出 "人员: " + 转为_文字(人员)
输出 "名字: " + 人员["名字"]

# 切片
文字列 = ["a", "b", "c", "d", "e"]
输出 "切片 [1:3]: " + 转为_文字(文字列[1:3])

# 全局
计数 = 0
定义 增加():
    全局 计数
    计数 = 计数 + 1
结束 函数
增加()
增加()
输出 "全局计数: " + 转为_文字(计数)

# PASS
定义 空函数():
    PASS
结束 函数
空函数()
输出 "PASS 有效"

# 字符串方法
s = "  你好世界  "
输出 "修剪: '" + 修剪(s) + "'"
输出 "大写: " + 大写(修剪(s))
输出 "小写: " + 小写(修剪(s))
输出 "替换: " + 替换(修剪(s), "世界", "Zuse")
部分 = 分割("a,b,c,d", ",")
输出 "分割: " + 转为_文字(部分)
输出 "包含 '你好': " + 转为_文字(包含(s, "你好"))
输出 "查找 '世界': " + 转为_文字(查找(修剪(s), "世界"))
输出 "开始于 '你好': " + 转为_文字(开头是(修剪(s), "你好"))
输出 "结束于 '世界': " + 转为_文字(结尾是(修剪(s), "世界"))

# 基本Builtins
数字列2 = [3, 1, 4, 1, 5, 9, 2, 6]
输出 "长度: " + 转为_文字(长度(数字列2))
输出 "最大值: " + 转为_文字(最大值(数字列2))
输出 "最小值: " + 转为_文字(最小值(数字列2))
输出 "绝对值(-5): " + 转为_文字(绝对值(-5))
输出 "四舍五入(3.7): " + 转为_文字(四舍五入(3.7))
输出 "平方根(16): " + 转为_文字(平方根(16))
输出 "转为_数字('42'): " + 转为_文字(转为_数字("42"))
输出 "是_数字(42): " + 转为_文字(是_数字(42))
输出 "是_文字('hi'): " + 转为_文字(是_文字("hi"))
输出 "是_列表([]): " + 转为_文字(是_列表([]))
输出 "是_字典({}): " + 转为_文字(是_字典({}))
输出 "是_布尔(真): " + 转为_文字(是_布尔(真))
输出 "是_空(空): " + 转为_文字(是_空(空))

输出 "=== 中文基础结束 ==="
