# zh_2_kubaozang.zuse - Chinese Program 2: Libraries (库包藏)
输出 "=== 中文库包藏 ==="

# 导入Python库
导入 math 作为 m
导入 random 作为 rnd
导入 os 作为 os_
导入 re 作为 regex
导入 json 作为 js
导入 datetime 作为 dt
导入 sys 作为 sys_

输出 "平台: " + 转为_文字(sys_.platform)

# 文件操作
文件名 = "test_output_zh.txt"
写入_文件(文件名, "第1行\n第2行\n第3行\n")
输出 "文件存在: " + 转为_文字(存在(文件名))
内容 = 读取_文件(文件名)
输出 "内容: " + 修剪(内容)
行列 = 读取_行(文件名)
输出 "行数: " + 转为_文字(长度(行列))
追加_文件(文件名, "第4行\n")
行列2 = 读取_行(文件名)
输出 "追加后: " + 转为_文字(长度(行列2))
删除_文件(文件名)
输出 "文件已删除: " + 转为_文字(非 存在(文件名))

# 列表Builtins
数字列 = [3, 1, 4, 1, 5, 9, 2, 6, 5, 3]
输出 "总和: " + 转为_文字(求和(数字列))
输出 "唯一: " + 转为_文字(唯一(数字列))
过滤的 = 过滤(数字列, 匿名(x): x > 3)
输出 "过滤 (>3): " + 转为_文字(过滤的)
映射的 = 映射(数字列, 匿名(x): x * 2)
输出 "映射 (*2): " + 转为_文字(映射的)
排序的 = 排序(数字列)
输出 "排序: " + 转为_文字(排序的)
颠倒的 = 反转(排序的)
输出 "颠倒: " + 转为_文字(颠倒的)
嵌套 = [[1, 2], [3, 4], [5, 6]]
输出 "展平: " + 转为_文字(展平(嵌套))
枚举的 = 枚举([ 10, 20, 30])
输出 "枚举: " + 转为_文字(枚举的)
组合 = 组合([1, 2, 3], ["a", "b", "c"])
输出 "组合: " + 转为_文字(组合)
追加值 = 追加([1, 2], 3, 4, 5)
输出 "追加: " + 转为_文字(追加值)
输出 "所有 > 0: " + 转为_文字(所有([1, 2, 3]))
输出 "任何 > 5: " + 转为_文字(任何([假, 真, 假]))

# 字符串Builtins
模板 = "你好 {0}, 你 {1} 岁了!"
输出 格式(模板, "小明", 25)
输出 "字符码 'A': " + 转为_文字(字符码("A"))
输出 "字符(65): " + 字符(65)
输出 "十六进制(255): " + HEX(255)
输出 "二进制(10): " + BIN(10)
输出 "八进制(8): " + OCT(8)

# 数学Builtins
输出 "PI: " + 转为_文字(四舍五入(PI, 4))
输出 "E: " + 转为_文字(四舍五入(E, 4))
输出 "正弦(0): " + 转为_文字(正弦(0))
输出 "余弦(0): " + 转为_文字(余弦(0))
输出 "正切(0): " + 转为_文字(正切(0))
输出 "对数(1): " + 转为_文字(对数(1))
输出 "下取整(3.7): " + 转为_文字(下取整(3.7))
输出 "上取整(3.2): " + 转为_文字(上取整(3.2))
输出 "幂(2,10): " + 转为_文字(幂(2, 10))
随机数 = 随机()
输出 "随机 [0,1): " + 转为_文字(四舍五入(随机数, 4))
随机范围 = 随机_范围(1, 100)
输出 "随机 [1,100]: " + 转为_文字(随机范围)

# 类型转换
输出 "转为_数字('3.14'): " + 转为_文字(转为_数字("3.14"))
输出 "转为_文字(42): " + 转为_文字(转为_文字(42))
输出 "是_数字(3.14): " + 转为_文字(是_数字(3.14))
输出 "是_文字('abc'): " + 转为_文字(是_文字("abc"))
输出 "是_列表([1]): " + 转为_文字(是_列表([1]))
输出 "是_字典({'a':1}): " + 转为_文字(是_字典({"a": 1}))
输出 "是_布尔(真): " + 转为_文字(是_布尔(真))
输出 "是_空(空): " + 转为_文字(是_空(空))

# math模块直接使用
输出 "math.pi: " + 转为_文字(四舍五入(m.pi, 4))
输出 "math.sqrt(9): " + 转为_文字(m.sqrt(9))

# json模块
数据 = {"名字": "Zuse", "版本": 7, "活跃": 真}
json文字 = js.dumps(数据)
输出 "JSON: " + json文字
加载的 = js.loads(json文字)
输出 "重新加载: " + 转为_文字(加载的)

# datetime
现在 = dt.datetime.now()
输出 "日期/时间: " + 转为_文字(现在.year) + "-" + 转为_文字(现在.month) + "-" + 转为_文字(现在.day)

# re模块
匹配 = regex.findall("[0-9]+", "abc123def456")
输出 "Regex匹配: " + 转为_文字(匹配)

输出 "=== 中文库包藏结束 ==="
