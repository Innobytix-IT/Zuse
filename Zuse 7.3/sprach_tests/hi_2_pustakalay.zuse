# Python पुस्तकालय आयात करें
आयात math जैसे m
आयात random जैसे rnd
आयात os जैसे os_
आयात re जैसे regex
आयात json जैसे js
आयात datetime जैसे dt
आयात sys जैसे sys_

दिखाओ "प्लेटफ़ॉर्म: " + पाठ_में(sys_.platform)

# फ़ाइल संचालन
फ़ाइल_नाम = "test_output_hi.txt"
लिखो_फ़ाइल(फ़ाइल_नाम, "पंक्ति 1\nपंक्ति 2\nपंक्ति 3\n")
दिखाओ "फ़ाइल मौजूद है: " + पाठ_में(मौजूद_है(फ़ाइल_नाम))
सामग्री = पढ़ो_फ़ाइल(फ़ाइल_नाम)
दिखाओ "सामग्री: " + छाँटो(सामग्री)
पंक्तियाँ = पढ़ो_पंक्तियाँ(फ़ाइल_नाम)
दिखाओ "पंक्तियाँ: " + पाठ_में(लंबाई(पंक्तियाँ))
जोड़ो_फ़ाइल(फ़ाइल_नाम, "पंक्ति 4\n")
पंक्तियाँ2 = पढ़ो_पंक्तियाँ(फ़ाइल_नाम)
दिखाओ "जोड़ने के बाद: " + पाठ_में(लंबाई(पंक्तियाँ2))
हटाओ_फ़ाइल(फ़ाइल_नाम)
दिखाओ "फ़ाइल हटाई गई: " + पाठ_में(नहीं मौजूद_है(फ़ाइल_नाम))

# सूची Builtins
संख्याएं = [3, 1, 4, 1, 5, 9, 2, 6, 5, 3]
दिखाओ "योग: " + पाठ_में(योग(संख्याएं))
दिखाओ "अनोखे: " + पाठ_में(अद्वितीय(संख्याएं))
छना_हुआ = छानो(संख्याएं, क्रिया(x): x > 3)
दिखाओ "छना हुआ (>3): " + पाठ_में(छना_हुआ)
बदला_हुआ = बदलो_सब(संख्याएं, क्रिया(x): x * 2)
दिखाओ "बदला हुआ (*2): " + पाठ_में(बदला_हुआ)
क्रमित = क्रमबद्ध(संख्याएं)
दिखाओ "क्रमित: " + पाठ_में(क्रमित)
उलटा = उलटाओ(क्रमित)
दिखाओ "उलटा: " + पाठ_में(उलटा)
नेस्टेड = [[1, 2], [3, 4], [5, 6]]
दिखाओ "समतल: " + पाठ_में(समतल(नेस्टेड))
गिना_हुआ = गिनती([ 10, 20, 30])
दिखाओ "गिना हुआ: " + पाठ_में(गिना_हुआ)
मिलाया = मिलाओ([1, 2, 3], ["a", "b", "c"])
दिखाओ "मिलाया: " + पाठ_में(मिलाया)
जोड़ा = जोड़ो_अंत([1, 2], 3, 4, 5)
दिखाओ "जोड़ा: " + पाठ_में(जोड़ा)
दिखाओ "सभी > 0: " + पाठ_में(सभी([1, 2, 3]))
दिखाओ "कोई > 5: " + पाठ_में(कोई([असत्य, सत्य, असत्य]))

# स्ट्रिंग Builtins
टेम्पलेट = "नमस्ते {0}, आपकी उम्र {1} है!"
दिखाओ प्रारूप(टेम्पलेट, "राम", 25)
दिखाओ "वर्ण_कोड 'A': " + पाठ_में(वर्ण_कोड("A"))
दिखाओ "वर्ण(65): " + वर्ण(65)
दिखाओ "Hex(255): " + HEX(255)
दिखाओ "Bin(10): " + BIN(10)
दिखाओ "Oct(8): " + OCT(8)

# गणित Builtins
दिखाओ "PI: " + पाठ_में(गोल(PI, 4))
दिखाओ "E: " + पाठ_में(गोल(E, 4))
दिखाओ "ज्या(0): " + पाठ_में(ज्या(0))
दिखाओ "कोज्या(0): " + पाठ_में(कोज्या(0))
दिखाओ "स्पर्शज्या(0): " + पाठ_में(स्पर्शज्या(0))
दिखाओ "लघुगणक(1): " + पाठ_में(लघुगणक(1))
दिखाओ "तल(3.7): " + पाठ_में(तल(3.7))
दिखाओ "छत(3.2): " + पाठ_में(छत(3.2))
दिखाओ "घात(2,10): " + पाठ_में(घात(2, 10))
यादृच्छिक = यादृच्छिक()
दिखाओ "यादृच्छिक [0,1): " + पाठ_में(गोल(यादृच्छिक, 4))
यादृच्छिक_सीमा = यादृच्छिक_श्रेणी(1, 100)
दिखाओ "यादृच्छिक [1,100]: " + पाठ_में(यादृच्छिक_सीमा)

# प्रकार रूपांतरण
दिखाओ "संख्या_में('3.14'): " + पाठ_में(संख्या_में("3.14"))
दिखाओ "पाठ_में(42): " + पाठ_में(पाठ_में(42))
दिखाओ "है_संख्या(3.14): " + पाठ_में(है_संख्या(3.14))
दिखाओ "है_पाठ('abc'): " + पाठ_में(है_पाठ("abc"))
दिखाओ "है_सूची([1]): " + पाठ_में(है_सूची([1]))
दिखाओ "है_शब्दकोश({'a':1}): " + पाठ_में(है_शब्दकोश({"a": 1}))
दिखाओ "है_बूल(सत्य): " + पाठ_में(है_बूल(सत्य))
दिखाओ "है_कुछनहीं(कुछनहीं): " + पाठ_में(है_कुछनहीं(कुछनहीं))

# math मॉड्यूल सीधे
दिखाओ "math.pi: " + पाठ_में(गोल(m.pi, 4))
दिखाओ "math.sqrt(9): " + पाठ_में(m.sqrt(9))

# json मॉड्यूल
डेटा = {"नाम": "Zuse", "संस्करण": 7, "सक्रिय": सत्य}
json_पाठ = js.dumps(डेटा)
दिखाओ "JSON: " + json_पाठ
वापस_लोड = js.loads(json_पाठ)
दिखाओ "वापस लोड: " + पाठ_में(वापस_लोड)

# datetime
अभी = dt.datetime.now()
दिखाओ "दिनांक/समय: " + पाठ_में(अभी.year) + "-" + पाठ_में(अभी.month) + "-" + पाठ_में(अभी.day)

# re मॉड्यूल
मिलान = regex.findall("[0-9]+", "abc123def456")
दिखाओ "Regex मिलान: " + पाठ_में(मिलान)

दिखाओ "=== हिंदी पुस्तकालय समाप्त ==="
